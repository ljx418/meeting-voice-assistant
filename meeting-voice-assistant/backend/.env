# DashScope 语音识别配置
# 使用 Qwen3-ASR-Flash 模型

# ASR 引擎选择: mock (测试), dashscope (DashScope)
ASR_ENGINE=dashscope

# DashScope API Key
DASHSCOPE_API_KEY=sk-0462c6e28e4349b49cd32673030646df

# DashScope 配置
DASHSCOPE_ENDPOINT=https://dashscope.aliyuncs.com/api/v1/services/audio/asr
DASHSCOPE_MODEL=qwen3-asr-flash

# 音频配置
AUDIO_SAMPLE_RATE=16000
AUDIO_CHANNELS=1

# 日志配置
LOG_LEVEL=INFO
