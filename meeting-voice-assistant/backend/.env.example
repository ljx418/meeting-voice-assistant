# 阿里云语音识别配置模板
# 复制此文件为 .env 并填入真实值

# ASR 引擎选择: mock (测试), aliyun (阿里云)
ASR_ENGINE=aliyun

# 阿里云 AccessKey
ALIYUN_ACCESS_KEY_ID=your_access_key_id
ALIYUN_ACCESS_KEY_SECRET=your_access_key_secret

# 阿里云语音服务 AppKey (必须)
# 获取方式:
# 1. 登录阿里云控制台 https://home.console.aliyun.com
# 2. 搜索 "智能语音交互"
# 3. 开通 "实时语音转写" 服务
# 4. 在 "项目管理" 中创建项目，获取 AppKey
ALIYUN_APP_KEY=your_app_key_here

# 阿里云服务区域和 endpoint
ALIYUN_REGION=cn-shanghai
ALIYUN_ENDPOINT=wss://nls-gateway.cn-shanghai.aliyuncs.com/ws/v1

# 音频配置
AUDIO_SAMPLE_RATE=16000
AUDIO_CHANNELS=1

# 日志配置
LOG_LEVEL=INFO
